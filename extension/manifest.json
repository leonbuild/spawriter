{
  "manifest_version": 3,
  "name": "spawriter",
  "short_name": "spawriter",
  "version": "1.0.0",
  "author": "LeonBuild",
  "homepage_url": "https://github.com/leonbuild/spawriter",
  "description": "spawriter devtools panel with MCP support (Manifest V3)",
  "action": {
    "default_icon": {
      "16": "./build/icons/icon-16.png",
      "32": "./build/icons/icon-32.png",
      "48": "./build/icons/icon-48.png",
      "128": "./build/icons/icon-128.png"
    },
    "default_title": "spawriter - Click to attach debugger"
  },
  "icons": {
    "16": "./build/icons/icon-16.png",
    "48": "./build/icons/icon-48.png",
    "128": "./build/icons/icon-128.png"
  },
  "devtools_page": "./build/main.html",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "scripting", "browsingData", "tabs", "debugger", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["./build/contentScriptMain.js"],
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["./build/contentScript.js"],
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "./build/backgroundScript.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "spawriter@single-spa.js.org",
      "strict_min_version": "109.0"
    }
  }
}
