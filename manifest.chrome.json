{
  "manifest_version": 3,
  "name": "spawriter",
  "short_name": "spawriter",
  "version": "1.0.0",
  "author": "LeonBuild",
  "homepage_url": "https://github.com/gzl333/spawriter",
  "description": "spawriter devtools panel with MCP support (Manifest V3)",
  "action": {
    "default_icon": {
      "16": "./icons/icon-16.png",
      "32": "./icons/icon-32.png",
      "48": "./icons/icon-48.png",
      "128": "./icons/icon-128.png"
    },
    "default_title": "spawriter - Click to attach debugger"
  },
  "icons": {
    "16": "./icons/icon-16.png",
    "48": "./icons/icon-48.png",
    "128": "./icons/icon-128.png"
  },
  "devtools_page": "./build/main.html",
  "permissions": ["storage", "scripting", "browsingData", "tabs", "tabGroups", "debugger"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["./build/contentScriptMain.js"],
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["./build/contentScript.js"],
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "./build/backgroundScript.js"
  }
}
